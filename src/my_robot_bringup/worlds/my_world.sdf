    <!-- Left wall TOP segment: from y=+0.5 to y=+3  (2.5m, centered at y=1.75) -->
    <model name='left_wall_top'>
      <static>true</static>
      <pose>-6.0 1.75 1.25 0 0 0</pose>
      <link name='link'>
        <collision name='collision'>
          <geometry><box><size>0.2 2.5 2.5</size></box></geometry>
