    <!-- ==================== ARUCO MARKERS ==================== -->
    <!-- Marker 0: on bottom wall (inside face, facing +y) near right side -->
    <include>
      <uri>file:///home/shreya/trial3_ihub/install/my_robot_bringup/share/my_robot_bringup/models/aruco_marker_0</uri>
      <name>aruco_marker_0</name>
      <pose>3.0 -2.8 1.0 0 0 1.570796</pose>
    </include>

    <!-- Marker 1: on right wall (inside face, facing -x) -->
    <include>
      <uri>file:///home/shreya/trial3_ihub/install/my_robot_bringup/share/my_robot_bringup/models/aruco_marker_1</uri>
      <name>aruco_marker_1</name>
      <pose>5.8 0.0 1.0 0 0 3.141593</pose>
    </include>

    <!-- Marker 2: on top wall (inside face, facing -y) -->
    <include>
