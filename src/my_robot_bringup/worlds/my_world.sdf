        </visual>
        <pose>0 0 0 0 0 0</pose>
        <inertial><pose>0 0 0 0 0 0</pose><mass>1</mass>
          <inertia><ixx>1</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1</iyy><iyz>0</iyz><izz>1</izz></inertia>
        </inertial>
        <enable_wind>false</enable_wind>
      </link>
      <self_collide>false</self_collide>
    </model>

    <!-- Left wall step bottom: horizontal shelf going inward at y=-0.5 -->
    <model name='left_wall_step_bottom'>
      <static>true</static>
      <pose>-5.25 -0.5 1.25 0 0 0</pose>
      <link name='link'>
        <collision name='collision'>
          <geometry><box><size>1.5 0.2 2.5</size></box></geometry>
          <surface><friction><ode/></friction><bounce/><contact/></surface>
        </collision>
        <visual name='visual'>
          <geometry><box><size>1.5 0.2 2.5</size></box></geometry>
          <material>
            <ambient>0.65 0.50 0.39 1</ambient>
            <diffuse>0.65 0.50 0.39 1</diffuse>
          </material>
        </visual>
        <pose>0 0 0 0 0 0</pose>
        <inertial><pose>0 0 0 0 0 0</pose><mass>1</mass>
          <inertia><ixx>1</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1</iyy><iyz>0</iyz><izz>1</izz></inertia>
        </inertial>
        <enable_wind>false</enable_wind>
      </link>
      <self_collide>false</self_collide>
    </model>

    <!-- Left wall step inner: vertical segment from y=-0.5 to y=+0.5 at x=-4.5 -->
    <model name='left_wall_step_inner'>
      <static>true</static>
      <pose>-4.5 0.0 1.25 0 0 0</pose>
      <link name='link'>
        <collision name='collision'>
          <geometry><box><size>0.2 1.0 2.5</size></box></geometry>
          <surface><friction><ode/></friction><bounce/><contact/></surface>
        </collision>
        <visual name='visual'>
          <geometry><box><size>0.2 1.0 2.5</size></box></geometry>
          <material>
            <ambient>0.65 0.50 0.39 1</ambient>
            <diffuse>0.65 0.50 0.39 1</diffuse>
