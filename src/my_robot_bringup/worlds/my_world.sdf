          <inertia><ixx>1</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1</iyy><iyz>0</iyz><izz>1</izz></inertia>
        </inertial>
        <enable_wind>false</enable_wind>
      </link>
      <self_collide>false</self_collide>
    </model>

    <!-- OPENING GAP at bottom: from x=-1 to x=+1  (2m wide) — no wall here -->

    <!-- Bottom wall RIGHT segment: from x=+1 to x=+6  (5m long, centered at x=3.5) -->
    <model name='bottom_wall_right'>
      <static>true</static>
      <pose>3.5 -3.0 1.25 0 0 0</pose>
      <link name='link'>
        <collision name='collision'>
          <geometry><box><size>5.0 0.2 2.5</size></box></geometry>
          <surface><friction><ode/></friction><bounce/><contact/></surface>
        </collision>
        <visual name='visual'>
          <geometry><box><size>5.0 0.2 2.5</size></box></geometry>
          <material>
            <ambient>0.65 0.50 0.39 1</ambient>
            <diffuse>0.65 0.50 0.39 1</diffuse>
          </material>
        </visual>
        <pose>0 0 0 0 0 0</pose>
        <inertial><pose>0 0 0 0 0 0</pose><mass>1</mass>
          <inertia><ixx>1</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1</iyy><iyz>0</iyz><izz>1</izz></inertia>
        </inertial>
        <enable_wind>false</enable_wind>
      </link>
      <self_collide>false</self_collide>
    </model>

    <!-- Left wall BOTTOM segment: from y=-3 to y=-0.5  (2.5m, centered at y=-1.75) -->
    <model name='left_wall_bottom'>
      <static>true</static>
      <pose>-6.0 -1.75 1.25 0 0 0</pose>
      <link name='link'>
        <collision name='collision'>
          <geometry><box><size>0.2 2.5 2.5</size></box></geometry>
          <surface><friction><ode/></friction><bounce/><contact/></surface>
        </collision>
        <visual name='visual'>
          <geometry><box><size>0.2 2.5 2.5</size></box></geometry>
          <material>
            <ambient>0.65 0.50 0.39 1</ambient>
            <diffuse>0.65 0.50 0.39 1</diffuse>
